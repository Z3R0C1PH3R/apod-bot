# NASA APOD API key (https://api.nasa.gov/)
NASA_API_KEY=

# Azure Speech (S0 — set voice/style/rate to taste)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_VOICE=en-US-Andrew:DragonHDLatestNeural
AZURE_SPEECH_STYLE=documentary-narration
AZURE_SPEECH_RATE=+12%
# Multilingual alternatives (style applies; not Dragon HD):
# AZURE_SPEECH_VOICE=en-US-AndrewMultilingualNeural
# AZURE_SPEECH_VOICE=en-US-AvaMultilingualNeural

# Azure Blob Storage (Instagram pulls video from here)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=videos

# Instagram Reels upload (optional)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=17841467200020320
